{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome with Dev Server",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "Start Dev Server"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome (Static File)",
      "file": "${workspaceFolder}/index.html"
    }
  ]
}
